				type="reset"
				class="win-btn"
			>
				<span class="font-semibold text-gray-700">Reset</span>
			</button>
			<button
				type="submit"
				class="win-btn"
			>
				<span class="font-semibold text-gray-700">💾 Save Journal</span>
			</button>
