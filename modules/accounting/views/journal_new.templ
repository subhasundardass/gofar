templ JournalEntryForm(props JournalProps) {
	<fieldset class="border border-gray-300 rounded-md mt-4 p-4">
		<legend class="px-2 text-sm font-semibold text-gray-700">Entry</legend>
		<div
			id="je-wrapper"
			data-signals={ fmt.Sprintf(`{"rowCount": %d}`, props.InitialRows) }
		>
			<div class="min-w-full text-sm" id="entry-body">
				for i := range props.InitialRows {
					@JournalEntryRow(i+1, props.Ledgers)
				}
			</div>
			<button
				class="win-btn mt-2"
				data-on:click="@get('/accounting/journal/new/newrow?index=' + ($rowCount + 1))"
			>
				Add Row
			</button>
		</div>
	</fieldset>
}

templ JournalEntryRow(index int, ledgers []form.Option) {
	<div
		id={ fmt.Sprintf("row-%d", index) }
		class="flex items-center gap-2 py-1"
	>
		<div class="w-28 shrink-0">
			<select
				name={ fmt.Sprintf("rows[%d][type]", index) }
				class="w-full"
			>
				<option value="D">Debit</option>
				<option value="C">Credit</option>
			</select>
		</div>
		<div class="flex-1">
			<select
				name={ fmt.Sprintf("rows[%d][account]", index) }
				class="w-full"
			>
				for _, l := range ledgers {
					<option value={ l.Value }>{ l.Label }</option>
				}
			</select>
		</div>
		<div class="flex-1">
			<input
				type="text"
				name={ fmt.Sprintf("rows[%d][desc]", index) }
				class="w-full"
			/>
		</div>
		<div class="w-32 shrink-0">
			<input
				type="number"
				name={ fmt.Sprintf("rows[%d][amount]", index) }
				class="w-full text-right"
				step="0.01"
			/>
		</div>
		<div class="w-24 shrink-0">
			<button
				type="button"
				class="win-btn"
			>
				Remove
			</button>
		</div>
	</div>
}

// journalFooter renders the overall narration + the save / reset buttons.
templ journalFooter() {
	// <fieldset class="border border-gray-300 rounded-md p-4">
	// 	<legend class="px-2 text-sm font-semibold text-gray-700">Narration</legend>
	// 	<div class="flex flex-col gap-2">
