package components

templ Toast() {
	<div
		id="toast"
		data-show="$toast.visible"
		class="fixed bottom-4 right-4 z-[9999] px-4 py-2 rounded text-white shadow-lg bg-gray-800"
	>
		<span data-text="$toast.message"></span>
		<button
			class="ml-3"
			data-on:click="$toast.visible=false"
		>
			✕
		</button>
	</div>
}
